// Esquema de datos: "¿Quién Quiere Ser Bendecido?" y "100 Cristianos Dijeron"

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OptionKey {
  A
  B
  C
  D
}

enum Category {
  ANTIGUO_TESTAMENTO
  NUEVO_TESTAMENTO
  PERSONAJES
  DOCTRINA
  VIDA_DE_JESUS
  GENERAL
}

enum SessionMode {
  TEAMS
  INDIVIDUAL
}

enum SessionStatus {
  SETUP
  IN_PROGRESS
  FINISHED
}

enum ParticipantStatus {
  ACTIVE
  WON
  WALKED_AWAY
  LOST
}

model Question {
  id            String   @id @default(cuid())
  text          String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption OptionKey
  difficulty    Int
  category      Category
  bibleVersion  String   @default("RV60")
  verseRef      String?
  verseText     String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessionQuestions SessionQuestion[]
}

model PrizeLevel {
  id           String  @id @default(cuid())
  step         Int     @unique
  label        String
  points       Int
  isCheckpoint Boolean @default(false)
}

model GameSession {
  id                    String        @id @default(cuid())
  mode                  SessionMode
  status                SessionStatus @default(SETUP)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  participants     Participant[]
  sessionQuestions SessionQuestion[]
}

model Participant {
  id                 String            @id @default(cuid())
  sessionId          String
  session            GameSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name               String
  order              Int
  score              Int               @default(0)
  currentStep        Int               @default(0)
  status             ParticipantStatus @default(ACTIVE)
  lifelineFiftyUsed  Boolean           @default(false)
  lifelineLeaderUsed Boolean           @default(false)
  lifelineTeamUsed   Boolean           @default(false)

  sessionQuestions SessionQuestion[]
}

// Preguntas ya barajadas y asignadas a un participante para una partida concreta.
// participantId permite que cada equipo/jugador tenga su propia escalera
// independiente de 15 preguntas dentro de la misma sesión.
model SessionQuestion {
  id                   String      @id @default(cuid())
  sessionId            String
  session              GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantId        String
  participant          Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  questionId           String
  question             Question    @relation(fields: [questionId], references: [id])
  step                 Int
  revealedFiftyOptions Json?
  answeredOption       OptionKey?
  isCorrect            Boolean?
  answeredAt           DateTime?

  @@unique([participantId, step])
}

// ---- "100 Cristianos Dijeron" (Family Feud) ----

enum FeudRoundPhase {
  FACEOFF
  PLAYING
  STEAL
  DONE
}

enum FeudTeam {
  TEAM_A
  TEAM_B
}

model FeudQuestion {
  id        String   @id @default(cuid())
  text      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers FeudAnswer[]
  rounds  FeudSessionRound[]
}

model FeudAnswer {
  id         String       @id @default(cuid())
  questionId String
  question   FeudQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  points     Int
  rank       Int

  @@unique([questionId, rank])
}

model FeudSession {
  id         String        @id @default(cuid())
  teamAName  String
  teamBName  String
  teamAScore Int           @default(0)
  teamBScore Int           @default(0)
  status     SessionStatus @default(SETUP)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  rounds FeudSessionRound[]
}

// Cada fila es una ronda completa de una partida, con su propio estado
// FACEOFF -> PLAYING -> STEAL -> DONE. Todas las rondas de una partida se
// crean de una vez al iniciarla; "la ronda actual" es la primera con phase != DONE.
model FeudSessionRound {
  id                String         @id @default(cuid())
  sessionId         String
  session           FeudSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId        String
  question          FeudQuestion   @relation(fields: [questionId], references: [id])
  roundNumber       Int
  phase             FeudRoundPhase @default(FACEOFF)
  controllingTeam   FeudTeam?
  strikes           Int            @default(0)
  revealedAnswerIds Json           @default("[]")
  pot               Int            @default(0)
  wonBy             FeudTeam?

  @@unique([sessionId, roundNumber])
}
